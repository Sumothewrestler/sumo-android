<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ Data Extraction (device-to-device transfer / cloud backup).
     We opt out of both — auth state belongs to a single device. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
